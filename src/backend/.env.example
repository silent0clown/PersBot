# Server Configuration
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
SERVER_RELOAD=false

# LLM Configuration (used by default)
LLM_PROVIDER=ollama
OLLAMA_MODEL=qwen3.5:2b
OLLAMA_BASE_URL=http://localhost:11434

# OpenAI Configuration (used when LLM_PROVIDER=openai)
# OPENAI_API_KEY=your-api-key-here
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-3.5-turbo

# Other API Configuration (used when LLM_PROVIDER=other)
# OTHER_API_KEY=your-api-key-here
# OTHER_BASE_URL=https://api.example.com/v1
# OTHER_MODEL=your-model-name

# Wake Word Configuration
# WAKE_KEYWORDS=["jarvis","贾维斯"]
# WAKE_SENSITIVITY=0.5
# PORCUPINE_ACCESS_KEY=your-porcupine-key

# ASR Configuration
# ASR_MODEL_SIZE=base
# ASR_LANGUAGE=
# ASR_DEVICE=auto

# TTS Configuration
# TTS_VOICE=xiaoxiao
# TTS_RATE=+0%
# TTS_VOLUME=+0%

# App Configuration
# APP_HOTKEY=ctrl+shift+space
# APP_START_MINIMIZED=false
# APP_AUTO_START=false

# MCP Configuration
# MCP servers can be configured via JSON in environment or use mcp_servers.yaml
# MCP_TIMEOUT=30

# Feishu Configuration
# FEISHU_ENABLED=false
# FEISHU_APP_ID=your-feishu-app-id
# FEISHU_APP_SECRET=your-feishu-app-secret
# FEISHU_VERIFICATION_TOKEN=your-verification-token
# FEISHU_ENCRYPT_KEY=your-encrypt-key
# FEISHU_DOMAIN=https://open.feishu.cn