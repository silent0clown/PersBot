# LLM Configuration
# Choose LLM provider: "ollama" or "openai" or "other"
LLM_PROVIDER=ollama

# For Ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen:7b

# For OpenAI or OpenAI-compatible APIs
# OPENAI_API_KEY=your-api-key-here
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-3.5-turbo

# For other OpenAI-compatible APIs (like Together AI, etc.)
# OTHER_API_KEY=your-api-key-here
# OTHER_BASE_URL=https://api.example.com/v1
# OTHER_MODEL=your-model-name