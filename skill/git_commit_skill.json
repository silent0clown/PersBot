{
  "name": "git_commit",
  "description": "Automatically commit changes to GitHub with meaningful commit messages",
  "version": "1.0.0",
  "author": "PersBot",
  "keywords": ["git", "commit", "github", "version control"],
  "main": "git_commit.py",
  "commands": {
    "commit": {
      "description": "Commit all relevant changes with auto-generated message",
      "usage": "persbot skill git_commit commit"
    },
    "commit-and-push": {
      "description": "Commit and push changes to remote",
      "usage": "persbot skill git_commit commit-and-push"
    }
  },
  "exclude_patterns": [
    "dist", "dist-electron", "build", "out", "__pycache__", ".pytest_cache",
    "node_modules", "venv", "env", ".venv", ".mypy_cache", ".ruff_cache",
    ".vscode", ".idea", ".vs", ".sublime-project", ".sublime-workspace",
    "*.log", "*.tmp", "*.temp", "logs", "tmp", "temp",
    ".DS_Store", "Thumbs.db", "desktop.ini",
    ".env", ".env.local", ".env.*", "secrets.json", "credentials.json",
    ".git", ".gitignore", ".gitattributes",
    "package-lock.json", "yarn.lock", "pnpm-lock.yaml", "Cargo.lock",
    "docs/_build", "site", ".docusaurus"
  ]
}